            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login correcto o requiere 2FA', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                  "if (json.twoFactorToken) pm.collectionVariables.set('twoFactorToken', json.twoFactorToken);",
                  "if (json.role) pm.collectionVariables.set('currentRole', json.role);"
