            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Ciudadano Postman Actualizado\",\n  \"email\": \"ciudadano.actualizado{{$timestamp}}@alerto.local\",\n  \"role\": \"Citizen\",\n  \"expectedVersion\": {{userVersion}}\n}"
            },
            "url": "{{baseUrl}}/api/v1/users/{{userId}}"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["if (pm.response.code === 200) { const json = pm.response.json(); pm.collectionVariables.set('userVersion', json.version); }"] } }]
        },
        {
          "name": "Desactivar usuario",
          "request": {
