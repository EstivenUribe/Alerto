    {
      "name": "06 - Pruebas negativas",
      "item": [
        {
          "name": "Endpoint protegido sin token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/alerts"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] } }]
        },
        {
          "name": "Login invalido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"incorrecta\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/login"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] } }]
        },
        {
          "name": "Confirmacion duplicada",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Intento duplicado para validar 409.\"\n}" },
            "url": "{{baseUrl}}/api/v1/alerts/{{alertId}}/citizen-confirm"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 409 si ya existia confirmacion', () => pm.expect([201, 409, 422]).to.include(pm.response.code));"] } }]
        }
      ]
    },
    {
      "name": "07 - Flujos por rol",
      "item": [
        {
          "name": "Crear reporte como Citizen",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{citizenAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reporte ciudadano {{$timestamp}}\",\n  \"description\": \"Ciudadano reporta una situacion que debe quedar pendiente de revision operativa.\",\n  \"severity\": \"Moderate\",\n  \"sourceSystem\": \"App ciudadana\",\n  \"address\": \"Calle 10 con Carrera 50, Medellin\",\n  \"latitude\": 6.244203,\n  \"longitude\": -75.581211,\n  \"geofenceId\": \"{{geofenceId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/alerts"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Citizen puede crear alerta pendiente', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.collectionVariables.set('alertId', json.id);", "pm.collectionVariables.set('alertVersion', json.version);"] } }]
        },
        {
          "name": "Aprobar reporte con Operator",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{operatorAccessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"expectedVersion\": {{alertVersion}}\n}" },
