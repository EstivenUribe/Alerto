          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Operator puede aprobar', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.collectionVariables.set('alertVersion', json.version);"] } }]
        },
        {
