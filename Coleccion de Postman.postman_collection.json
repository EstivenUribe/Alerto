              "raw": "{\n  \"username\": \"ciudadano{{$timestamp}}\",\n  \"displayName\": \"Ciudadano Postman\",\n  \"email\": \"ciudadano{{$timestamp}}@alerto.local\",\n  \"password\": \"Ciudadano2026!\",\n  \"role\": \"Citizen\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/users"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));", "const json = pm.response.json();", "pm.collectionVariables.set('userId', json.id);", "pm.collectionVariables.set('userVersion', json.version);"] } }]
        },
        {
          "name": "Consultar usuario por id",
          "request": {
