            },
            "url": "{{baseUrl}}/api/v1/alerts/{{alertId}}/dispatch"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('RulesEngine puede difundir', () => pm.response.to.have.status(200));", "const json = pm.response.json();", "pm.collectionVariables.set('alertVersion', json.version);"] } }]
        },
        {
          "name": "Consultar clima como Citizen",
          "request": {
