              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"expectedVersion\": {{userVersion}},\n  \"reason\": \"Prueba Postman\"\n}" },
            "url": "{{baseUrl}}/api/v1/users/{{userId}}/deactivate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["if (pm.response.code === 200) { const json = pm.response.json(); pm.collectionVariables.set('userVersion', json.version); }"] } }]
        },
        {
          "name": "Activar usuario",
