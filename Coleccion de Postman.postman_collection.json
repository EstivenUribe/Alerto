              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expectedVersion\": {{alertVersion}},\n  \"channel\": \"Sms\",\n  \"destination\": \"+573001234567\",\n  \"providerReference\": \"OPERATOR-DENIED-{{$timestamp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/alerts/{{alertId}}/dispatch"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Operator recibe 403 al difundir', () => pm.response.to.have.status(403));"] } }]
        },
