{
  "Observability": {
    "EnableBodyLogging": true,
    "MaxLoggedBodyLength": 4096
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 240,
    "WindowSeconds": 60,
    "AuthPermitLimit": 40,
    "AuthWindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    }
  }
}
