{
  "ConnectionStrings": {
    "AlertoDb": "Host=localhost;Port=5433;Database=alerto_db;Username=postgres;Password=postgres",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer": "alerto-api",
    "Audience": "alerto-clients",
    "SecretKey": "Alerto.Super.Secret.Key.For.DotNet.8.Api.2026",
    "AccessTokenMinutes": 15,
    "TwoFactorTokenMinutes": 5,
    "MachineTokenMinutes": 10
  },
  "BootstrapAdmin": {
    "Username": "admin",
    "DisplayName": "Administrador Alerto",
    "Email": "admin@alerto.local",
    "Password": "AlertoAdmin123!"
  },
  "MachineClients": {
    "Clients": [
      {
        "ClientId": "rules-engine",
        "ClientSecret": "rules-engine-secret",
        "DisplayName": "Rules Engine COE",
        "Role": "RulesEngine",
        "Scope": "alerts:read alerts:dispatch"
      }
    ]
  },
  "Integrations": {
    "OpenMeteo": {
      "BaseUrl": "https://api.open-meteo.com/",
      "TimeoutSeconds": 5,
      "RetryCount": 2,
      "CircuitBreakerFailures": 3,
      "CircuitBreakerBreakSeconds": 60
    },
    "Siata": {
      "BaseUrl": "https://siata.local/",
      "SimulationMode": true,
      "TimeoutSeconds": 3,
      "RetryCount": 2,
      "CircuitBreakerFailures": 3,
      "CircuitBreakerBreakSeconds": 30,
      "CacheMinutes": 5,
      "HealthPath": "/health"
    },
    "CapGenerator": {
      "BaseUrl": "https://cap-generator.local/",
      "SimulationMode": true,
      "TimeoutSeconds": 5,
      "RetryCount": 2,
      "CircuitBreakerFailures": 3,
      "CircuitBreakerBreakSeconds": 30,
      "HealthPath": "/health"
    },
    "CellBroadcast": {
      "BaseUrl": "https://cell-broadcast.local/",
      "SimulationMode": true,
      "TimeoutSeconds": 5,
      "RetryCount": 2,
      "CircuitBreakerFailures": 3,
      "CircuitBreakerBreakSeconds": 45,
      "DuplicateWindowMinutes": 10,
      "HealthPath": "/health"
    },
    "NotificationPublisher": {
      "SimulationMode": true,
      "UseOutbox": true,
      "NotificationTopic": "alerto.notifications",
      "AuditTopic": "alerto.audit"
    },
    "Outbox": {
      "Enabled": true,
      "ProcessInProcess": true,
      "BatchSize": 20,
      "PollIntervalSeconds": 10
    }
  },
  "Observability": {
    "EnableBodyLogging": false,
    "MaxLoggedBodyLength": 2048,
    "MetricsRoute": "/metrics/basic",
    "SensitiveFields": [
      "password",
      "newPassword",
      "clientSecret",
      "refreshToken",
      "accessToken",
      "twoFactorToken",
      "code",
      "secret",
      "totpSecret",
      "token"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 120,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "AuthPermitLimit": 20,
    "AuthWindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Alerts": {
    "ApprovalTimeoutMinutes": 3,
    "CacheTtlMinutes": 5
  },
  "AllowedHosts": "*"
}
